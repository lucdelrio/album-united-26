{
  "name": "Album Utd 26",
  "slug": "album-united-26",
  "scheme": "albumutd26",
  "icon": "./assets/logo-album-united-26.png",
  "orientation": "portrait",
  "plugins": [
    [
      "react-native-google-mobile-ads",
      {
        "iosAppId": "ca-app-pub-3940256099942544~1458002511",
        "androidAppId": "ca-app-pub-3940256099942544~3347511713"
      }
    ]
  ],
  "android": {
    "package": "com.album.united26"
  },
  "ios": {
    "bundleIdentifier": "com.album.united26",
    "deploymentTarget": "15.1",
    "infoPlist": {
      "NSUserTrackingUsageDescription": "We use your data to provide more relevant ads.",
      "NSLocalNetworkUsageDescription": "Allow local network access to connect to the Metro development server.",
      "NSBonjourServices": [
        "_expo._tcp",
        "_http._tcp",
        "_react-native._tcp"
      ]
    }
  }
}
